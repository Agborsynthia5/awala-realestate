# ─── App ──────────────────────────────────────────────────────────────
APP_NAME="Awala RealEstate API"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=change_this_to_a_random_secret_key_in_production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:61859
ALLOW_ORIGIN_REGEX=^http://localhost(:[0-9]+)?$

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://awala:awala_secret@localhost:5432/awala_db
DATABASE_URL_SYNC=postgresql://awala:awala_secret@localhost:5432/awala_db

# ─── JWT Auth ─────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_this_jwt_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Meilisearch ──────────────────────────────────────────────────────
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=awala_meili_key

# ─── Cloudinary ───────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Firebase FCM ─────────────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ─── Geospatial ───────────────────────────────────────────────────────
MOLYKO_JUNCTION_LAT=4.1527
MOLYKO_JUNCTION_LNG=9.2345

# ─── Local Uploads (offline-friendly dev storage) ───────────────────
UPLOAD_DIR=/app/uploads
PUBLIC_BASE_URL=http://localhost:8001
